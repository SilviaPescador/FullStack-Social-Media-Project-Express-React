{
  "name": "fullstack-social-media",
  "version": "1.0.0",
  "private": true,
  "description": "Red social fullstack - Express + React (Vite)",
  "engines": {
    "node": ">=24.0.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": ["bcrypt", "esbuild"],
    "overrides": {
      "tar": ">=7.5.10",
      "serialize-javascript": ">=7.0.3"
    }
  },
  "scripts": {
    "dev": "pnpm --stream -r --parallel run dev",
    "dev:backend": "pnpm --filter equipo3backend dev",
    "dev:frontend": "pnpm --filter frontend-react dev",
    "build": "pnpm --filter frontend-react build",
    "test": "pnpm --filter equipo3backend test",
    "audit:all": "cd Backend && pnpm audit && cd ../frontend-react && pnpm audit"
  }
}
